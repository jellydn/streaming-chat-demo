{
  "name": "streaming-chat-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint src server",
    "lint:fix": "oxlint src server --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.78",
    "hono": "^4.7.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.8",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6",
    "concurrently": "10"
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "6",
    "vite": "8"
  }
}
